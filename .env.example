TRADIER_API_KEY=your_tradier_api_key
TRADIER_ENV=sandbox
# TRADIER_ACCOUNT_ID — auto-detected on first run if blank
TRADIER_ACCOUNT_ID=
POLYGON_API_KEY=your_polygon_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
# KOTORI_DB — defaults to ~/.kotori/kotori.db; uncomment to override
# KOTORI_DB=~/.kotori/kotori.db
# KOTORI_SEED_MOCK=1 — demo mode: seed mock data at startup AND register
# stub recurring jobs (fake IV ingest, fake IC scan, no-op order executor).
# Leave unset for live trading; only stable, real-data jobs run.
# KOTORI_SEED_MOCK=
# KOTORI_WATCHLIST — comma-separated tickers for the candidate scanner.
# Defaults to the 10 most-liquid optionable names (SPY, QQQ, IWM, AAPL,
# NVDA, TSLA, MSFT, AMZN, META, GOOGL) if unset.
# KOTORI_WATCHLIST=SPY,QQQ,IWM
# DISCORD_WEBHOOK_URL — when set, the daemon posts each new alert
# (profit_target, stop_loss, force_close, ic_placed, gap_risk) to this
# Discord channel as a colored embed. Polled every 30s, decoupled from
# alert writing — a Discord outage doesn't break local alerting.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>
