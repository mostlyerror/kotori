# Keep the build context small: anything that isn't source the image needs.

.git/
.gitignore
.github/

.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Local dev state — never goes into a production image
.env
.env.*
!.env.example
.kotori/
.worktrees/

# Test artifacts and docs (image runs the daemon, not docs/tests)
tests/
docs/
.superpowers/
scripts/

# Editor noise
.DS_Store
.idea/
.vscode/
*.swp
